{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "Agent",
      "Skill",
      "WebSearch",
      "WebFetch",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "TeamCreate",
      "TeamDelete",
      "SendMessage",
      "Bash(*)"
    ],
    "ask": [
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(npx create:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(git push origin dev:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git rebase:*)",
      "Bash(git reset --hard:*)",
      "Bash(git reset --mixed:*)",
      "Bash(git reset --soft:*)",
      "Bash(git amend:*)",
      "Bash(git commit --amend:*)",
      "Bash(git filter-branch:*)",
      "Bash(git reflog expire:*)",
      "Bash(git gc --prune:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git revert:*)",
      "Bash(git bisect:*)"
    ]
  }
}
